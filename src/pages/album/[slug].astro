---
import Layout from "@/layouts/Layout.astro"
import HeaderShared from "@/components/HeaderShared.astro"
import Footer from "@/components/Footer.astro"
import AudioPreview from "@/components/AudioPreview.astro"
import { getAlbumBySlug, type Album } from "@/data/albums"

const { slug } = Astro.params
const album: Album | undefined = getAlbumBySlug(slug || "")

if (!album) {
  return Astro.redirect("/404", 302)
}

const SITE_URL = "https://lllitmts.vercel.app"
const getWebpUrl = (url: string) => url.replace(/\.png$/, ".webp").replace(/\.jpg$/, ".webp")
const getAvifUrl = (url: string) => url.replace(/\.png$/, ".avif").replace(/\.jpg$/, ".avif")
const FULL_COVER_URL = `${SITE_URL}${album.coverUrl}`

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MusicGroup",
      "@id": `${SITE_URL}/#artist`,
      "name": "LLLIT",
      "url": SITE_URL,
      "sameAs": [
        album.bandcampUrl,
        album.instagramUrl,
        album.youtubeUrl,
        album.soundcloudUrl,
      ]
    },
    {
      "@type": "MusicAlbum",
      "@id": `${SITE_URL}/album/${album.slug}#album`,
      "name": album.title,
      "byArtist": { "@id": `${SITE_URL}/#artist` },
      "datePublished": album.releaseDate,
      "numTracks": album.tracks.length,
      "genre": album.genres,
      "image": FULL_COVER_URL,
      "albumReleaseType": "https://schema.org/AlbumRelease",
      "track": album.tracks.map((t, i) => ({
        "@type": "MusicRecording",
        "position": i + 1,
        "name": t.name,
      })),
      "offers": {
        "@type": "Offer",
        "url": album.bandcampUrl,
        "price": album.price.replace("$", "").replace(" USD", ""),
        "priceCurrency": "USD",
        "availability": "https://schema.org/PreOrder",
      }
    }
  ]
}
---

<Layout
  hideKeepScrolling
  title={`LLLIT — ${album.title} (${album.genres.join(", ")}) 2026`}
  description={album.descriptionEn}
  ogTitle={`LLLIT — ${album.title}`}
  ogDescription={album.descriptionEn}
  ogImage={FULL_COVER_URL}
  structuredData={structuredData}
  canonicalUrl={`${SITE_URL}/album/${album.slug}`}
  breadcrumbs={[
    { name: "LLLIT", url: "/" },
    { name: album.title, url: `/album/${album.slug}` },
  ]}
>
  <HeaderShared />

  <main class="min-h-screen bg-[#111] text-white">
    <div class="relative overflow-hidden pt-16">
      <div class="absolute inset-0 opacity-[0.04]">
        <img src={album.visualBgUrl} alt="" class="w-full h-full object-cover" aria-hidden="true" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-b from-[#111] via-transparent to-[#111]"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-5 sm:px-8 py-16 md:py-24">
        <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
          <div class="animate-in-left">
            <div class="relative">
              <div class="absolute -inset-1.5 bg-white/[0.04] rounded-3xl blur-sm"></div>
              <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl" style="aspect-ratio: 1 / 1">
                <picture>
                  <source srcset={getWebpUrl(album.coverUrl)} type="image/webp" />
                  <img
                    src={album.coverUrl}
                    alt={`${album.title} — Álbum de ${album.artist} por Camila Bravo`}
                    class="w-full h-full object-cover"
                    fetchpriority="high"
                    decoding="async"
                  />
                </picture>
              </div>
            </div>
          </div>

          <div class="animate-in-right">
            <p class="text-[11px] tracking-[0.15em] uppercase text-white/40 mb-2 font-medium">
              {album.artist} · {album.label}
            </p>
            <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-[0.92] tracking-tighter mb-4">
              {album.title}
            </h1>

            <div class="flex flex-wrap gap-2.5 mb-6">
              <span class="text-[11px] tracking-[0.12em] uppercase text-white/50 px-3 py-1.5 border border-white/10 rounded-full">
                {album.releaseType}
              </span>
              <span class="text-[11px] tracking-[0.12em] uppercase text-amber-200/70 px-3 py-1.5 border border-amber-200/20 rounded-full">
                {album.campaignDate}
              </span>
              <span class="text-[11px] tracking-[0.12em] uppercase text-white/50 px-3 py-1.5 border border-white/10 rounded-full">
                {album.price}
              </span>
              {album.genres.map((g) => (
                <span class="text-[10px] tracking-[0.08em] text-white/30 px-2.5 py-1 border border-white/[0.06] rounded-full">
                  {g}
                </span>
              ))}
            </div>

            <p class="text-sm text-white/50 leading-relaxed max-w-lg mb-8">
              {album.description}
            </p>

            <a
              href={album.bandcampUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2.5 px-6 py-3 text-sm font-medium tracking-[0.08em] uppercase bg-white/10 hover:bg-white/15 border border-white/15 hover:border-white/25 rounded-full transition-all mb-8"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
              Pre-order en Bandcamp
            </a>
            <a
              href="/redeem"
              class="inline-flex items-center gap-1.5 text-[11px] tracking-[0.1em] uppercase text-white/30 hover:text-white/60 transition-colors mb-8 ml-4"
            >
              ¿Tenés un código promocional? Canjealo
              <span class="text-white/20">&rarr;</span>
            </a>

            <div class="mb-8" data-content-visibility>
              <h2 class="text-[10px] tracking-[0.18em] uppercase text-white/30 mb-3 pb-2 border-b border-white/[0.06]">
                Tracklist
              </h2>
              <div class="space-y-0.5">
                {album.tracks.map((t) => (
                  <div class="flex items-center gap-2 py-2.5 border-b border-white/[0.04] group hover:border-white/10 transition-colors">
                    {t.previewUrl ? (
                      <AudioPreview src={t.previewUrl} trackName={t.name} />
                    ) : (
                      <span class="w-7 shrink-0 text-[11px] text-white/30 font-mono text-center">{t.num}</span>
                    )}
                    <span class="text-sm text-white/80 group-hover:text-white transition-colors flex-1">{t.name}</span>
                    <span class="text-[11px] text-white/30 font-mono tabular-nums">{t.bpm}</span>
                    <div class="h-[2px] w-16 bg-white/5 rounded overflow-hidden shrink-0 hidden sm:block">
                      <div class="h-full bg-white/30 rounded" style={`width: ${t.pct}%`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div class="grid grid-cols-2 gap-2 mb-8 max-w-md">
              {album.credits.map((c) => (
                <div class="px-3 py-2 bg-white/[0.02] border border-white/[0.06] rounded-md">
                  <p class="text-[9px] tracking-[0.12em] uppercase text-white/30 mb-0.5">{c.role}</p>
                  <p class="text-xs font-medium text-white/70">{c.name}</p>
                </div>
              ))}
            </div>

            <div class="flex flex-wrap gap-3">
              <a
                href={album.bandcampUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-5 py-2.5 text-xs font-medium tracking-[0.08em] uppercase bg-white/10 hover:bg-white/15 border border-white/15 hover:border-white/25 rounded-full transition-all"
              >
                <span class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
                Bandcamp
              </a>
              <a
                href={album.instagramUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-5 py-2.5 text-xs font-medium tracking-[0.08em] uppercase bg-white/[0.04] hover:bg-white/10 border border-white/10 hover:border-white/20 rounded-full transition-all"
              >
                {album.instagramHandle}
              </a>
              <a
                href={album.youtubeUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-5 py-2.5 text-xs font-medium tracking-[0.08em] uppercase bg-white/[0.04] hover:bg-white/10 border border-white/10 hover:border-white/20 rounded-full transition-all"
              >
                YouTube
              </a>
              <a
                href={album.soundcloudUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-5 py-2.5 text-xs font-medium tracking-[0.08em] uppercase bg-white/[0.04] hover:bg-white/10 border border-white/10 hover:border-white/20 rounded-full transition-all"
              >
                SoundCloud
              </a>
            </div>
          </div>
        </div>

        <div class="mt-24 text-center">
          <a
            href="/"
            class="inline-flex items-center gap-2 text-xs tracking-[0.1em] uppercase text-white/30 hover:text-white/60 transition-colors"
          >
            <span>&larr;</span>
            Volver a LLLIT
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap"
  gsap.from(".animate-in-left", {
    x: -80,
    opacity: 0,
    duration: 0.8,
    ease: "power2.out",
  })
  gsap.from(".animate-in-right", {
    x: 80,
    opacity: 0,
    duration: 0.8,
    ease: "power2.out",
    delay: 0.15,
  })
</script>
