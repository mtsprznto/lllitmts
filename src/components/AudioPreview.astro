---
interface Props {
  src: string
  trackName: string
}

const { src, trackName } = Astro.props
const PREVIEW_DURATION = 30
---

<button
  class="audio-play-btn group w-7 h-7 shrink-0 rounded-full border border-white/15 hover:border-white/30 bg-white/[0.04] hover:bg-white/10 flex items-center justify-center transition-all cursor-pointer"
  data-src={src}
  data-duration={PREVIEW_DURATION}
  aria-label={`Reproducir preview de ${trackName}`}
>
  <svg class="play-icon w-3 h-3 text-white/50 group-hover:text-white/80 transition-colors" viewBox="0 0 12 14" fill="currentColor">
    <path d="M0 0v14l12-7z" />
  </svg>
  <svg class="stop-icon w-3 h-3 text-white/80 hidden" viewBox="0 0 12 14" fill="currentColor">
    <rect width="10" height="10" x="1" y="2" rx="1" />
  </svg>
</button>

<script>
  let currentPlayer: HTMLAudioElement | null = null
  let currentBtn: HTMLElement | null = null

  document.querySelectorAll<HTMLElement>(".audio-play-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const src = btn.dataset.src
      const duration = Number(btn.dataset.duration) || 30

      if (currentPlayer && currentBtn === btn) {
        currentPlayer.pause()
        currentPlayer.currentTime = 0
        currentPlayer = null
        currentBtn?.classList.remove("playing")
        currentBtn = null
        toggleIcons(btn, false)
        return
      }

      if (currentPlayer) {
        currentPlayer.pause()
        currentPlayer.currentTime = 0
        currentBtn?.classList.remove("playing")
        toggleIcons(currentBtn as HTMLElement, false)
      }

      const audio = new Audio(src)
      audio.volume = 0.8
      currentPlayer = audio
      currentBtn = btn
      btn.classList.add("playing")
      toggleIcons(btn, true)

      audio.addEventListener("timeupdate", () => {
        if (audio.currentTime >= duration) {
          audio.pause()
          audio.currentTime = 0
          btn.classList.remove("playing")
          toggleIcons(btn, false)
          currentPlayer = null
          currentBtn = null
        }
      })

      audio.addEventListener("ended", () => {
        btn.classList.remove("playing")
        toggleIcons(btn, false)
        currentPlayer = null
        currentBtn = null
      })

      audio.play().catch(() => {
        btn.classList.remove("playing")
        toggleIcons(btn, false)
        currentPlayer = null
        currentBtn = null
      })
    })
  })

  function toggleIcons(btn: HTMLElement, playing: boolean) {
    const playIcon = btn.querySelector(".play-icon") as HTMLElement
    const stopIcon = btn.querySelector(".stop-icon") as HTMLElement
    if (playIcon) playIcon.classList.toggle("hidden", playing)
    if (stopIcon) stopIcon.classList.toggle("hidden", !playing)
  }
</script>

<style is:inline>
  .audio-play-btn.playing {
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.1);
  }
</style>
