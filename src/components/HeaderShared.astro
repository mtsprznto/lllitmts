<nav
  class="fixed border-b border-white/30 top-0 left-0 w-full bg-black/50 backdrop-blur-md z-[9999]"
>
  <div class="flex justify-between">
    <span class="ml-2">
      <a href="/">
        <span class="font-bold tracking-tighter text-lg">LLLIT</span>
      </a>
    </span>
    <div class="flex justify-end tracking-tighter z-9999">
      <a
        id="nav-album"
        class="z-9999 cursor-pointer h-full hover:bg-white/30 px-2"
        href="/album"
      >
        Discografía
      </a>
      <a
        id="contacto"
        class="z-9999 cursor-pointer h-full hover:bg-white/30 px-2"
        href="/formulario"
      >
        Contacto
      </a>
    </div>
  </div>
</nav>

<script>
  import { gsap } from "gsap";

  gsap.from("nav button", {
    y: 60,
    opacity: 0,
    duration: 0.8,
    ease: "power2.out",
    stagger: 0.2, // animación en cascada
  });
</script>
